// ============================================================
// AgriPortal — Jenkins Declarative Pipeline
// Task 5: CI/CD Pipeline
//
// Stages:
//   1. Checkout SCM
//   2. Environment Check
//   3. Build Docker Images
//   4. Run Docker Containers (docker-compose up)
//   5. Health Check
//   6. Notification
// ============================================================

pipeline {

    // ── Agent ────────────────────────────────────────────────
    agent any

    // ── Pipeline-wide Environment Variables ──────────────────
    environment {
        COMPOSE_PROJECT_NAME = 'agri-portal'
        REGISTRY             = 'docker.io'          // change to your registry
        IMAGE_TAG            = "${BUILD_NUMBER}"
        GIT_REPO             = 'https://github.com/your-org/agri-portal.git'  // update with actual repo
        DOCKER_CREDENTIALS   = 'docker-hub-creds'   // Jenkins credentials ID
    }

    // ── Build Options ────────────────────────────────────────
    options {
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
        ansiColor('xterm')
    }

    // ── Triggers ─────────────────────────────────────────────
    triggers {
        pollSCM('H/5 * * * *')   // Poll every 5 minutes (replace with webhook in production)
    }

    // ── Stages ───────────────────────────────────────────────
    stages {

        // ── Stage 1: Checkout Source Code ──────────────────
        stage('Checkout SCM') {
            steps {
                echo '============================================='
                echo ' STAGE 1: Checking out source code from SCM '
                echo '============================================='
                checkout scm
                sh 'echo "Workspace: ${WORKSPACE}"'
                sh 'ls -la'
                sh 'git log --oneline -5'
            }
        }

        // ── Stage 2: Environment Verification ──────────────
        stage('Environment Check') {
            steps {
                echo '======================================='
                echo ' STAGE 2: Verifying build environment '
                echo '======================================='
                sh '''
                    echo "--- Docker version ---"
                    docker --version

                    echo "--- Docker Compose version ---"
                    docker compose version || docker-compose --version

                    echo "--- Node.js version ---"
                    node --version || echo "Node.js not installed on agent"

                    echo "--- Available disk space ---"
                    df -h

                    echo "--- Current user ---"
                    whoami
                '''
            }
        }

        // ── Stage 3: Build Docker Images ───────────────────
        stage('Build Docker Images') {
            parallel {
                stage('Build farmer-service') {
                    steps {
                        echo 'Building farmer-service image...'
                        sh '''
                            docker build \
                                -t agri-portal/farmer-service:${IMAGE_TAG} \
                                -t agri-portal/farmer-service:latest \
                                ./farmer-service
                        '''
                    }
                }
                stage('Build crop-service') {
                    steps {
                        echo 'Building crop-service image...'
                        sh '''
                            docker build \
                                -t agri-portal/crop-service:${IMAGE_TAG} \
                                -t agri-portal/crop-service:latest \
                                ./crop-service
                        '''
                    }
                }
                stage('Build scheme-service') {
                    steps {
                        echo 'Building scheme-service image...'
                        sh '''
                            docker build \
                                -t agri-portal/scheme-service:${IMAGE_TAG} \
                                -t agri-portal/scheme-service:latest \
                                ./scheme-service
                        '''
                    }
                }
                stage('Build api-gateway') {
                    steps {
                        echo 'Building api-gateway image...'
                        sh '''
                            docker build \
                                -t agri-portal/api-gateway:${IMAGE_TAG} \
                                -t agri-portal/api-gateway:latest \
                                ./api-gateway
                        '''
                    }
                }
                stage('Build angular-ui') {
                    steps {
                        echo 'Building angular-ui image (may take a few minutes)...'
                        sh '''
                            docker build \
                                -t agri-portal/angular-ui:${IMAGE_TAG} \
                                -t agri-portal/angular-ui:latest \
                                ./angular-ui
                        '''
                    }
                }
            }
        }

        // ── Stage 4: Run Docker Containers ─────────────────
        stage('Deploy with Docker Compose') {
            steps {
                echo '================================================='
                echo ' STAGE 4: Starting containers with Docker Compose '
                echo '================================================='
                sh '''
                    # Stop any existing containers
                    docker compose down --remove-orphans || true

                    # Start all services in detached mode
                    docker compose up -d --no-build

                    # Wait for containers to stabilize
                    echo "Waiting 30s for services to start..."
                    sleep 30

                    # Show running containers
                    echo "--- Running Containers ---"
                    docker compose ps
                '''
            }
        }

        // ── Stage 5: Health Checks ──────────────────────────
        stage('Health Check') {
            steps {
                echo '================================='
                echo ' STAGE 5: Running health checks '
                echo '================================='
                sh '''
                    MAX_RETRIES=6
                    WAIT_SEC=10

                    check_service() {
                        local name=$1
                        local url=$2
                        local retries=0
                        echo "Checking $name at $url..."
                        while [ $retries -lt $MAX_RETRIES ]; do
                            if curl -sf "$url" > /dev/null 2>&1; then
                                echo "  ✅ $name is healthy"
                                return 0
                            fi
                            retries=$((retries + 1))
                            echo "  ⏳ $name not ready (attempt $retries/$MAX_RETRIES), waiting ${WAIT_SEC}s..."
                            sleep $WAIT_SEC
                        done
                        echo "  ❌ $name failed health check after $MAX_RETRIES attempts"
                        return 1
                    }

                    check_service "farmer-service"  "http://localhost:18081/health"
                    check_service "crop-service"    "http://localhost:18082/health"
                    check_service "scheme-service"  "http://localhost:18083/health"
                    check_service "api-gateway"     "http://localhost:18080/api/farmers"
                    check_service "angular-ui"      "http://localhost:14200"

                    echo ""
                    echo "=== All services healthy! ==="
                '''
            }
        }

        // ── Stage 6: API Smoke Tests ────────────────────────
        stage('API Smoke Test') {
            steps {
                echo '=================================='
                echo ' STAGE 6: Running API smoke tests '
                echo '=================================='
                sh '''
                    echo "Testing /api/farmers endpoint..."
                    RESULT=$(curl -sf http://localhost:18080/api/farmers)
                    echo "farmers response: $RESULT"

                    echo "Testing /api/crops endpoint..."
                    RESULT=$(curl -sf http://localhost:18080/api/crops)
                    echo "crops response: $RESULT"

                    echo "Testing /api/schemes endpoint..."
                    RESULT=$(curl -sf http://localhost:18080/api/schemes)
                    echo "schemes response: $RESULT"

                    echo "✅ All API smoke tests passed"
                '''
            }
        }
    }

    // ── Post-Build Actions ────────────────────────────────────
    post {
        always {
            echo 'Pipeline finished — collecting logs...'
            sh 'docker compose logs --tail=50 || true'
        }
        success {
            echo '''
            ╔══════════════════════════════════════════╗
            ║  ✅ BUILD SUCCESSFUL — AgriPortal Deployed ║
            ╠══════════════════════════════════════════╣
            ║  Angular UI   → http://localhost:4200     ║
            ║  API Gateway  → http://localhost:8080     ║
            ║  Farmer API   → http://localhost:8081     ║
            ║  Crop API     → http://localhost:8082     ║
            ║  Scheme API   → http://localhost:8083     ║
            ╚══════════════════════════════════════════╝
            '''
        }
        failure {
            echo '❌ BUILD FAILED — Check logs above for details'
            sh '''
                echo "=== Container Status ==="
                docker compose ps || true

                echo "=== Postgres Logs ==="
                docker compose logs postgres --tail=30 || true

                echo "=== farmer-service Logs ==="
                docker compose logs farmer-service --tail=20 || true
            '''
        }
        cleanup {
            // Uncomment to stop containers after pipeline:
            // sh 'docker compose down || true'
            cleanWs()
        }
    }
}
